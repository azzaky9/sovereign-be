{
  "name": "sovereign-be",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "worker:pending-tx": "bun run src/workers/pending-tx-worker.ts",
    "dev:all": "concurrently \"bun run dev\" \"bun run worker:pending-tx\"",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "seed": "bun run src/db/seed.ts",
    "studio": "drizzle-kit studio",
    "check": "drizzle-kit check",
    "push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:reset": "bun run src/db/reset.ts && bun run migrate && bun run seed"
  },
  "dependencies": {
    "bullmq": "^5.73.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "ioredis": "^5.6.1",
    "pg": "^8.20.0",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
