{
  "name": "sovereign-be",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:socket": "bun run --hot src/ws/server.ts",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:socket\"",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "seed": "bun run src/db/seed.ts",
    "studio": "drizzle-kit studio",
    "check": "drizzle-kit check",
    "push": "drizzle-kit push",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "ioredis": "^5.6.1",
    "pg": "^8.20.0",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
